APP_ENV=staging
MONGO_URL=mongodb+srv://USER:PASSWORD@CLUSTER/pmub_staging?retryWrites=true&w=majority
DB_NAME=pmub_staging
JWT_SECRET=replace-with-render-generated-or-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-staging-only-password
ADMIN_PASSCODE=replace-with-temporary-staging-passcode
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=180
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BACKOFF_SECONDS=4
CORS_ORIGINS=https://pmublonab-staging-web.onrender.com,https://pmublonab-staging-admin.onrender.com
